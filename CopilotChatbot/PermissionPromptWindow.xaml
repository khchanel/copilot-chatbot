<Window x:Class="CopilotChatbot.PermissionPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Permission Request"
        Height="440"
        Width="620"
        MinHeight="380"
        MinWidth="540"
        WindowStartupLocation="CenterOwner"
        Background="#F3F5F8">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FAFBFC" />
        <SolidColorBrush x:Key="ControlBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="BorderBrushModern" Color="#D0D7DE" />
        <SolidColorBrush x:Key="TextBrush" Color="#1F2328" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5D6673" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0A65CC" />

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource ControlBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushModern}"
                BorderThickness="0,0,0,1"
                Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="#101828" CornerRadius="10" Width="42" Height="42" Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="Shield20"
                                   Foreground="#6CB6FF"
                                   FontSize="23"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Copilot wants additional access"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="Choose whether this approval is temporary or saved for future requests."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushModern}"
                BorderThickness="0,1,0,0"
                Padding="18,14">
            <WrapPanel HorizontalAlignment="Right">
                <Button Content="Deny"
                        Style="{StaticResource ActionButton}"
                        Width="82"
                        Margin="0,0,8,0"
                        Click="Deny_Click" />
                <Button Content="Allow once"
                        Style="{StaticResource ActionButton}"
                        Width="106"
                        Margin="0,0,8,0"
                        Click="AllowOnce_Click" />
                <Button Content="Allow session"
                        Style="{StaticResource ActionButton}"
                        Width="126"
                        Margin="0,0,8,0"
                        Click="AllowSession_Click" />
                <Button Content="Save setting"
                        Width="118"
                        Height="36"
                        Padding="14,0"
                        Background="{StaticResource AccentBrush}"
                        Foreground="#FFFFFF"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="SaveSetting_Click" />
            </WrapPanel>
        </Border>

        <Grid Margin="22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushModern}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="KindTextBlock"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="ScopeTextBlock"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushModern}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="DetailsTextBox"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource TextBrush}"
                             FontFamily="Consolas"
                             FontSize="12"
                             Padding="14" />
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
