<Window x:Class="CopilotChatbot.UserInputPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Copilot Question"
        Height="520"
        Width="680"
        MinHeight="420"
        MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#F3F5F8">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FAFBFC" />
        <SolidColorBrush x:Key="ControlBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="BorderBrushModern" Color="#D0D7DE" />
        <SolidColorBrush x:Key="TextBrush" Color="#1F2328" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5D6673" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0A65CC" />

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource ControlBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushModern}"
                BorderThickness="0,0,0,1"
                Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="#101828" CornerRadius="10" Width="42" Height="42" Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="ChatBubblesQuestion20"
                                   Foreground="#6CB6FF"
                                   FontSize="23"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Copilot needs your input"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="Choose one of the suggested answers or type your own response."
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushModern}"
                BorderThickness="0,1,0,0"
                Padding="18,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource ActionButton}"
                        Width="88"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button x:Name="UseSelectedButton"
                        Content="Use selected"
                        Style="{StaticResource ActionButton}"
                        Width="116"
                        Margin="0,0,8,0"
                        Click="UseSelected_Click" />
                <Button x:Name="SendAnswerButton"
                        Content="Send answer"
                        Width="116"
                        Height="36"
                        Padding="14,0"
                        Background="{StaticResource AccentBrush}"
                        Foreground="#FFFFFF"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="SendAnswer_Click" />
            </StackPanel>
        </Border>

        <Grid Margin="22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushModern}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
                <TextBlock x:Name="QuestionTextBlock"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="14"
                           TextWrapping="Wrap" />
            </Border>

            <Border x:Name="ChoicesPanel"
                    Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushModern}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="0"
                    Margin="0,0,0,12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Suggested choices"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="12,10,12,6" />
                    <ListBox x:Name="ChoicesListBox"
                             BorderThickness="0"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource TextBrush}"
                             MouseDoubleClick="ChoicesListBox_MouseDoubleClick" />
                </DockPanel>
            </Border>

            <Border x:Name="FreeformPanel"
                    Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushModern}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Your answer"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="AnswerTextBox"
                             MinHeight="76"
                             MaxHeight="140"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="{StaticResource ControlBrush}"
                             Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrushModern}"
                             BorderThickness="1"
                             Padding="9" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
