<Window x:Class="CopilotChatbot.UserInputPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Copilot Question"
        Height="520"
        Width="680"
        MinHeight="420"
        MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="{DynamicResource PageBrush}">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{DynamicResource ControlBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushModern}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ControlHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#B8C2CC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource DisabledControlBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0856B3" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#0856B3" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#0648A0" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#0648A0" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource DisabledControlBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChoiceItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderBrushModern}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource ControlBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource AccentSoftBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushModern}"
                BorderThickness="0,0,0,1"
                Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Background="#101828" CornerRadius="10" Width="42" Height="42" Margin="0,0,14,0">
                    <ui:SymbolIcon Symbol="ChatBubblesQuestion20"
                                   Foreground="#6CB6FF"
                                   FontSize="23"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Copilot needs your input"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="Choose one of the suggested answers or type your own response."
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushModern}"
                BorderThickness="0,1,0,0"
                Padding="18,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{DynamicResource ActionButton}"
                        Width="88"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button x:Name="UseSelectedButton"
                        Content="Use selected"
                        Style="{DynamicResource ActionButton}"
                        Width="116"
                        Margin="0,0,8,0"
                        Click="UseSelected_Click" />
                <Button x:Name="SendAnswerButton"
                        Content="Send answer"
                        Width="116"
                        Style="{DynamicResource AccentButton}"
                        Click="SendAnswer_Click" />
            </StackPanel>
        </Border>

        <Grid Margin="22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrushModern}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,12">
                <TextBlock x:Name="QuestionTextBlock"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="14"
                           TextWrapping="Wrap" />
            </Border>

            <Border x:Name="ChoicesPanel"
                    Grid.Row="1"
                    MinHeight="120"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrushModern}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="0"
                    Margin="0,0,0,12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Suggested choices"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="12,10,12,6" />
                    <ListBox x:Name="ChoicesListBox"
                             BorderThickness="0"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource TextBrush}"
                             ItemContainerStyle="{StaticResource ChoiceItem}"
                             Padding="4,2,4,6"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="ChoicesListBox_MouseDoubleClick" />
                </DockPanel>
            </Border>

            <Border x:Name="FreeformPanel"
                    Grid.Row="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrushModern}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Your answer"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBox x:Name="AnswerTextBox"
                             MinHeight="76"
                             MaxHeight="140"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource ControlBrush}"
                             Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource BorderBrushModern}"
                             BorderThickness="1"
                             Padding="9" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
